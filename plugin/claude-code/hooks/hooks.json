{
  "description": "brain-context hooks — injects code intelligence protocol and ensures tools are loaded",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh",
            "timeout": 5,
            "statusMessage": "Loading brain-context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/user-prompt-submit.sh",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
